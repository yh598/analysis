# 1. Imports
from snowflake.snowpark.functions import col
from snowflake.ml.modeling.preprocessing import StringIndexer, Pipeline
from snowflake.ml.modeling.xgboost import XGBClassifier
import pandas as pd
import matplotlib.pyplot as plt
import numpy as np
np.float = np.float64  # for NumPy 2.0+

# 2. Detect object (VARCHAR) columns
object_cols = [col_name for col_name, dtype in df.dtypes if dtype == "VARCHAR"]
print("Categorical columns:", object_cols)

# 3. Encode object columns using StringIndexer
indexers = [
    (f"{col}_index", StringIndexer(input_cols=[col], output_cols=[f"{col}_index"]))
    for col in object_cols
]

pipeline_steps = [step for _, step in indexers]
pipeline = Pipeline(steps=pipeline_steps)
pipeline_model = pipeline.fit(df)
df_encoded = pipeline_model.transform(df)

# 4. Drop original object columns
df_encoded = df_encoded.drop(*object_cols)

# 5. Train/test split
train_df, test_df = df_encoded.randomSplit([0.8, 0.2], seed=42)

# 6. Train XGBoost model
model = XGBClassifier(max_depth=5, n_estimators=100)
model.fit(train_df, "FRAUD")

# 7. Predict (optional)
pred_df = model.predict(test_df)

# 8. Feature importance
feat_imp = model.get_feature_importances()
feat_df = pd.DataFrame(feat_imp.items(), columns=["feature", "importance"])
top20 = feat_df.sort_values("importance", ascending=False).head(20)
top20_features = top20["feature"].tolist()
top20_features.append("FRAUD")

# 9. Save top 20 features DataFrame
df_top20 = df_encoded.select([col(f) for f in top20_features])
df_top20.write.save_as_table("TOP20_FEATURE_DATA", mode="overwrite")

# 10. Plot top 20
plt.figure(figsize=(10, 6))
plt.barh(top20["feature"], top20["importance"])
plt.gca().invert_yaxis()
plt.xlabel("Importance")
plt.title("Top 20 Feature Importances — XGBoost")
plt.tight_layout()
plt.show()



