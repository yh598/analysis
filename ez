    for peak in zero_peaks:
        ax1.axvline(pdf["RECORD_MONTH"].iloc[peak], color="blue", linestyle="--", alpha=0.3)

    anomaly_peaks, _ = find_peaks(pdf[f"{feature}_ANOMALY_RATIO"], height=0.05)
    for peak in anomaly_peaks:
        ax2.axvline(pdf["RECORD_MONTH"].iloc[peak], color="red", linestyle=":", alpha=0.3)

