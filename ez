ip_features = session.sql("""
WITH base AS (
  SELECT
    USAA_PARTY_PD_ID,
    SESSION_CREATE_TS,
    IP_ADDRESS_TXT,
    TRY_TO_DOUBLE(GPS_YCOORD_TXT) AS LAT,
    TRY_TO_DOUBLE(GPS_XCOORD_TXT) AS LNG,
    LAG(SESSION_CREATE_TS) OVER (PARTITION BY USAA_PARTY_PD_ID ORDER BY SESSION_CREATE_TS) AS PREV_SESSION_TS,
    LAG(IP_ADDRESS_TXT) OVER (PARTITION BY USAA_PARTY_PD_ID ORDER BY SESSION_CREATE_TS) AS PREV_IP,
    LAG(TRY_TO_DOUBLE(GPS_YCOORD_TXT)) OVER (PARTITION BY USAA_PARTY_PD_ID ORDER BY SESSION_CREATE_TS) AS PREV_LAT,
    LAG(TRY_TO_DOUBLE(GPS_XCOORD_TXT)) OVER (PARTITION BY USAA_PARTY_PD_ID ORDER BY SESSION_CREATE_TS) AS PREV_LNG
  FROM PBKFRDDW.SMF_M_FRD_CU_WEBSESSION_DTL
  WHERE STATE_CD <> 'None' AND IP_ADDRESS_TXT <> '0.0.0.0'
),

joined AS (
  SELECT
    a.USAA_PARTY_PD_ID,
    a.PARTITION_DT,
    b.SESSION_CREATE_TS,
    b.IP_ADDRESS_TXT,
    
    DATEDIFF('day', b.SESSION_CREATE_TS, a.PARTITION_DT) AS DAYS_SINCE_LAST_IP_CHANGE,
    TIMESTAMPDIFF('second', b.PREV_SESSION_TS, b.SESSION_CREATE_TS) / 3600.0 AS TIME_LAPSE_HOURS,

    -- Haversine formula
    2 * 3958.8 * ASIN(SQRT(
      POWER(SIN(RADIANS(b.LAT - b.PREV_LAT) / 2), 2) +
      COS(RADIANS(b.PREV_LAT)) * COS(RADIANS(b.LAT)) *
      POWER(SIN(RADIANS(b.LNG - b.PREV_LNG) / 2), 2)
    )) AS DISTANCE_MILES,

    CASE WHEN b.IP_ADDRESS_TXT <> b.PREV_IP THEN 1 ELSE 0 END AS IP_CHANGE_FLAG,

    CASE 
      WHEN 
        2 * 3958.8 * ASIN(SQRT(
          POWER(SIN(RADIANS(b.LAT - b.PREV_LAT) / 2), 2) +
          COS(RADIANS(b.PREV_LAT)) * COS(RADIANS(b.LAT)) *
          POWER(SIN(RADIANS(b.LNG - b.PREV_LNG) / 2), 2)
        )) > 100
        AND TIMESTAMPDIFF('second', b.PREV_SESSION_TS, b.SESSION_CREATE_TS) / 3600.0 <= 1
      THEN 1 ELSE 0 
    END AS IMPOSSIBLE_TRAVEL_FLAG

  FROM base b
  JOIN BNK22952_E225.DESTRO_DIGITAL_TRAIN a
    ON a.USAA_PARTY_PD_ID = b.USAA_PARTY_PD_ID
  WHERE b.SESSION_CREATE_TS <= a.PARTITION_DT
),

ranked_sessions AS (
  SELECT *,
    ROW_NUMBER() OVER (PARTITION BY USAA_PARTY_PD_ID, PARTITION_DT ORDER BY SESSION_CREATE_TS DESC) AS rn
  FROM joined
),

agg AS (
  SELECT 
    USAA_PARTY_PD_ID,
    PARTITION_DT,
    COUNT(DISTINCT IP_ADDRESS_TXT) AS UNIQUE_IP_COUNT,
    MAX(DAYS_SINCE_LAST_IP_CHANGE) AS DAYS_SINCE_LAST_IP_CHANGE,
    MAX(TIME_LAPSE_HOURS) AS TIME_LAPSE_SINCE_LAST_SESSION,
    MAX(DISTANCE_MILES) AS DISTANCE_FROM_LAST_SESSION,
    MAX(IP_CHANGE_FLAG) AS IP_CHANGE_FLAG,
    MAX(IMPOSSIBLE_TRAVEL_FLAG) AS IMPOSSIBLE_TRAVEL_FLAG
  FROM ranked_sessions
  WHERE rn = 1
  GROUP BY USAA_PARTY_PD_ID, PARTITION_DT
)

SELECT * FROM agg
""")

