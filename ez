def split_by_id_balanced_smart(df, id_col, target_fraction=0.8, random_state=42):
    """
    Split a Snowpark DataFrame into train/test by ID, balancing IDs and approximating row counts.
    """
    # 1. Count number of rows per ID
    id_counts = df.group_by(id_col).count().to_pandas()
    id_counts.rename(columns={"COUNT": "count"}, inplace=True)

    # 2. Shuffle IDs
    id_counts = id_counts.sample(frac=1, random_state=random_state).reset_index(drop=True)

    # 3. Allocate IDs for train
    total_rows = df.count()
    target_train_rows = target_fraction * total_rows

    train_ids = []
    train_row_sum = 0

    for idx, row in id_counts.iterrows():
        train_ids.append(row[id_col])
        train_row_sum += row['count']
        if train_row_sum >= target_train_rows:
            break

    # 4. Remaining IDs → test
    all_ids = set(id_counts[id_col])
    test_ids = list(all_ids - set(train_ids))

    # 5. Split df
    train_df = df.filter(df[id_col].isin(train_ids))
    test_df = df.filter(df[id_col].isin(test_ids))

    return train_df, test_df

