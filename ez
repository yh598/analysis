from pyspark.sql.types import NumericType, DoubleType

# -------------------
# 1. Drop non-numeric columns
# -------------------
def drop_non_numeric_columns(df):
    numeric_cols = [f.name for f in df.schema.fields if isinstance(f.dataType, NumericType)]
    return df.select(*numeric_cols)

# -------------------
# 2. Test column-by-column for safe cast
# -------------------
def find_safe_columns(df):
    safe_cols = []
    for col in df.columns:
        try:
            # Try simple aggregation, if fails, column is bad
            df.select(F.col(col).cast("double")).agg(F.sum(F.col(col))).collect()
            safe_cols.append(col)
        except Exception as e:
            print(f"Column {col} unsafe, dropped. Error: {e}")
    return safe_cols

# -------------------
