    FROM PBKGPDMDB.APP_ENT_MBRHUB.CFCR_SV_EMAIL_EVENT
    WHERE CUST_EMAIL_ADDR_TXT IS NOT NULL AND TRIM(CUST_EMAIL_ADDR_TXT) <> ''
) b
JOIN BNK22952_E225.FAM_INTERNET_TRAIN_2024_11_0825_03 a
    ON a.USAA_PARTY_PD_ID = b.PRTY_ID
GROUP BY a.USAA_PARTY_PD_ID, a.PARTITION_DT



SELECT 
    a.USAA_PARTY_PD_ID,
    a.PARTITION_DT,
    COUNT(DISTINCT cleaned_phone_number) AS TOTAL_UNIQUE_PHONES,
    DATEDIFF(
        'day',
        MAX(
            CASE 
                WHEN b.CNTC_PT_VER_GMT_TS <= a.PARTITION_DT THEN b.CNTC_PT_VER_GMT_TS 
                ELSE NULL 
            END
        ),
        a.PARTITION_DT
    ) AS DAYS_SINCE_LAST_PHONE_CHANGE
FROM (
    SELECT 
        PRTY_ID,
        CNTC_PT_VER_GMT_TS,
        CASE 
            WHEN INTL_PHONE_NR IS NOT NULL AND TRIM(INTL_PHONE_NR) <> '' 
                THEN REGEXP_REPLACE(INTL_PHONE_NR, '[\\s()\\-]', '')
            ELSE REGEXP_REPLACE(CONCAT(PHONE_AREA_CD, PHONE_NR), '[\\s()\\-]', '')
        END AS cleaned_phone_number
    FROM PBKGPDMDB.APP_ENT_MRHUB.CFCR_SV_PHONE_EVENT
    WHERE 
        (INTL_PHONE_NR IS NOT NULL AND TRIM(INTL_PHONE_NR) <> '')
        OR 
        (PHONE_NR IS NOT NULL AND PHONE_AREA_CD IS NOT NULL AND TRIM(PHONE_NR) <> '' AND TRIM(PHONE_AREA_CD) <> '')
) b
JOIN BNK22952_E225.FAM_INTERNET_TRAIN_2024_11_0825_03 a
    ON a.USAA_PARTY_PD_ID = b.PRTY_ID
GROUP BY a.USAA_PARTY_PD_ID, a.PARTITION_DT


SELECT 
    a.USAA_PARTY_PD_ID,
    a.PARTITION_DT,
    COUNT(DISTINCT cleaned_phone_number) AS TOTAL_UNIQUE_PHONES,
    DATEDIFF(
        a.PARTITION_DT, 
        MAX(
            CASE 
                WHEN CNTC_PT_VER_GMT_TS <= a.PARTITION_DT THEN CNTC_PT_VER_GMT_TS 
                ELSE NULL 
            END
        )
    ) AS DAYS_SINCE_LAST_PHONE_CHANGE
FROM (
    SELECT 
        PRTY_ID,
        CNTC_PT_VER_GMT_TS,
        -- Normalize and merge phone numbers
        CASE 
            WHEN INTL_PHONE_NR IS NOT NULL AND TRIM(INTL_PHONE_NR) <> '' 
                THEN REGEXP_REPLACE(INTL_PHONE_NR, '[\\s()\\-]', '')
            ELSE REGEXP_REPLACE(concat(PHONE_AREA_CD, PHONE_NR), '[\\s()\\-]', '')
        END AS cleaned_phone_number
    FROM PBKGPDMDB.APP_ENT_MRHUB.CFCR_SV_PHONE_EVENT
    WHERE 
        (INTL_PHONE_NR IS NOT NULL AND TRIM(INTL_PHONE_NR) <> '')
        OR 
        (PHONE_NR IS NOT NULL AND PHONE_AREA_CD IS NOT NULL AND TRIM(PHONE_NR) <> '' AND TRIM(PHONE_AREA_CD) <> '')
) b
JOIN BNK22952_E225_DETRO_DIGITAL_TRAIN a
    ON a.USAA_PARTY_PD_ID = b.PRTY_ID
GROUP BY a.USAA_PARTY_PD_ID, a.PARTITION_DT


phone = session.sql("""
    SELECT 
        PRTY_ID,
        MAX(
            CASE 
                WHEN ROW_NUM_FIRST_USE = 1 THEN CNTC_PT_VER_GMT_TS 
            END
        ) AS LAST_PHONE_CHANGE_TS,
        COUNT(DISTINCT CLEANED_PHONE_NUMBER) AS TOTAL_UNIQUE_PHONES
    FROM (
        SELECT 
            PRTY_ID,
            CNTC_PT_VER_GMT_TS,
            -- Use INTL_PHONE_NR if available, otherwise fallback to domestic
            CASE 
                WHEN INTL_PHONE_NR IS NOT NULL AND TRIM(INTL_PHONE_NR) <> '' 
                    THEN REGEXP_REPLACE(INTL_PHONE_NR, '[\\s()\\-]', '')
                ELSE REGEXP_REPLACE(concat(PHONE_AREA_CD, PHONE_NR), '[\\s()\\-]', '')
            END AS CLEANED_PHONE_NUMBER,
            ROW_NUMBER() OVER (
                PARTITION BY PRTY_ID, 
                             CASE 
                                 WHEN INTL_PHONE_NR IS NOT NULL AND TRIM(INTL_PHONE_NR) <> '' 
                                     THEN REGEXP_REPLACE(INTL_PHONE_NR, '[\\s()\\-]', '')
                                 ELSE REGEXP_REPLACE(concat(PHONE_AREA_CD, PHONE_NR), '[\\s()\\-]', '')
                             END
                ORDER BY CNTC_PT_VER_GMT_TS ASC
            ) AS ROW_NUM_FIRST_USE
        FROM PBKGPDMDB.APP_ENT_MRHUB.CFCR_SV_PHONE_EVENT
        WHERE 
            (INTL_PHONE_NR IS NOT NULL AND TRIM(INTL_PHONE_NR) <> '')
            OR 
            (PHONE_NR IS NOT NULL AND PHONE_AREA_CD IS NOT NULL AND TRIM(PHONE_NR) <> '' AND TRIM(PHONE_AREA_CD) <> '')
    )
    GROUP BY PRTY_ID
""")

