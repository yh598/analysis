from datetime import datetime, timedelta

def create_partitioned_phone_features(session, base_table: str, phone_session_table: str, start_date: str, end_date: str):
    n_days_list = [1, 3, 7, 30, 60]
    all_queries = []

    # Generate date partitions
    current_date = datetime.strptime(start_date, "%Y-%m-%d")
    stop_date = datetime.strptime(end_date, "%Y-%m-%d")
    date_list = []

    while current_date <= stop_date:
        date_list.append(current_date.strftime("%Y-%m-%d"))
        current_date += timedelta(days=1)

    for partition_date in date_list:
        # Step 1: Create base phone list view
        base_phone_list_sql = f"""
        CREATE OR REPLACE TEMP VIEW base_phone_list_{partition_date.replace('-', '_')} AS
        SELECT 
            USAA_PARTY_PD_ID AS base_party_id,
            EVENT_TS AS base_event_ts,
            CASE 
                WHEN INTL_PHONE_NR IS NOT NULL AND TRIM(INTL_PHONE_NR) <> '' THEN REGEXP_REPLACE(INTL_PHONE_NR, '[^\\d]', '')
                WHEN PHONE_NR IS NOT NULL AND PHONE_AREA_CD IS NOT NULL THEN REGEXP_REPLACE(CONCAT(PHONE_AREA_CD, PHONE_NR), '[^\\d]', '')
                ELSE NULL
            END AS cleaned_phone_number
        FROM {phone_session_table}
        WHERE DATE_TRUNC('day', TO_DATE(EVENT_TS)) = TO_DATE('{partition_date}')
        """
        session.sql(base_phone_list_sql).collect()

        # Step 2: Filter phones with >= 3 members
        shared_filter_sql = f"""
        CREATE OR REPLACE TEMP VIEW shared_phones_only_{partition_date.replace('-', '_')} AS
        SELECT 
            cleaned_phone_number
        FROM base_phone_list_{partition_date.replace('-', '_')}
        GROUP BY cleaned_phone_number
        HAVING COUNT(DISTINCT base_party_id) >= 3
        """
        session.sql(shared_filter_sql).collect()

        # Step 3: Join and calculate features
        shared_join_sql = f"""
        CREATE OR REPLACE TEMP VIEW shared_phone_usage_{partition_date.replace('-', '_')} AS
        SELECT 
            bp.base_party_id,
            bp.base_event_ts,
            bp.cleaned_phone_number,
            pb.USAA_PARTY_PD_ID AS other_party_id,
            pb.CNTC_PT_VER_GMT_TS AS other_event_ts
        FROM base_phone_list_{partition_date.replace('-', '_')} bp
        JOIN shared_phones_only_{partition_date.replace('-', '_')} sp
        ON bp.cleaned_phone_number = sp.cleaned_phone_number
        JOIN {phone_session_table} pb
        ON bp.cleaned_phone_number = 
            CASE 
                WHEN pb.INTL_PHONE_NR IS NOT NULL AND TRIM(pb.INTL_PHONE_NR) <> '' THEN REGEXP_REPLACE(pb.INTL_PHONE_NR, '[^\\d]', '')
                WHEN pb.PHONE_NR IS NOT NULL AND pb.PHONE_AREA_CD IS NOT NULL THEN REGEXP_REPLACE(CONCAT(pb.PHONE_AREA_CD, pb.PHONE_NR), '[^\\d]', '')
                ELSE NULL
            END
        WHERE pb.CNTC_PT_VER_GMT_TS < bp.base_event_ts
        """
        session.sql(shared_join_sql).collect()

        # Step 4: Aggregate features
        feature_exprs = []
        for n in n_days_list:
            feature_exprs.append(f"""
                COUNT(DISTINCT CASE 
                    WHEN DATEDIFF(day, other_event_ts, base_event_ts) <= {n} 
                    THEN other_party_id 
                END) AS other_members_sharing_phone_last_{n}_days
            """)
            feature_exprs.append(f"""
                COUNT(DISTINCT CASE 
                    WHEN DATEDIFF(day, phone_event_ts, base_event_ts) <= {n} 
                    THEN cleaned_phone_number 
                END) AS phone_added_last_{n}_days
            """)

        final_sql = f"""
        SELECT
            base_party_id AS PRVT_ID,
            base_event_ts,
            {','.join(feature_exprs)}
        FROM base_phone_list_{partition_date.replace('-', '_')} bp
        LEFT JOIN shared_phone_usage_{partition_date.replace('-', '_')} spu
        ON bp.base_party_id = spu.base_party_id
        AND bp.base_event_ts = spu.base_event_ts
        GROUP BY base_party_id, base_event_ts
        """
        all_queries.append(final_sql)

    union_sql = "\nUNION ALL\n".join(all_queries)
    final_df = session.sql(union_sql)
    final_df.create_or_replace_temp_view("phone")

    return final_df

