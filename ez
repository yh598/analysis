def generate_clean_create_table(table_name: str, raw_columns: list, prefix_to_remove: str) -> str:
    cleaned_columns = [
        line.replace('"', '').replace(prefix_to_remove, '').strip().rstrip(',')
        for line in raw_columns
    ]
    column_definitions = ",\n    ".join(cleaned_columns)
    create_table_sql = f"""CREATE OR REPLACE TABLE {table_name} (
    {column_definitions}
);"""
    return create_table_sql

