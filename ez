SELECT 
    a.USAA_PARTY_PD_ID,
    a.PARTITION_DT,
    COUNT(DISTINCT b.COMPLETE_ADDRESS) AS TOTAL_UNIQUE_ADDRESSES,
    DATEDIFF(
        'day',
        MAX(
            CASE 
                WHEN b.CNTC_PT_VER_GMT_TS <= a.PARTITION_DT THEN b.CNTC_PT_VER_GMT_TS 
                ELSE NULL 
            END
        ),
        a.PARTITION_DT
    ) AS DAYS_SINCE_LAST_ADDRESS_CHANGE
FROM (
    SELECT 
        PRTY_ID,
        CNTC_PT_VER_GMT_TS,
        CONCAT_WS(' ',
            COALESCE(DOMS.DLV_R_ADDR_LINE_1_TXT, ''),
            COALESCE(DOMS.DLV_R_ADDR_LINE_2_TXT, ''),
            COALESCE(DOMS.DLV_R_ADDR_LINE_3_TXT, ''),
            COALESCE(DOMS.CITY_NM, ''),
            COALESCE(DOMS.CTRY_SERV_CD, ''),
            COALESCE(DOMS.PSTL_AREA_CD, ''),
            COALESCE(DOMS.PSTL_AREA_CA_DLV_ROUTE_CD, '')
        ) AS COMPLETE_ADDRESS
    FROM PBKGPDMDB.APP_ENT_MBRHUB.CFCR_SV_DOMS_ADDR_EVENT DOMS
    WHERE 
        DOMS.DLV_R_ADDR_LINE_1_TXT IS NOT NULL 
        OR DOMS.DLV_R_ADDR_LINE_2_TXT IS NOT NULL 
        OR DOMS.DLV_R_ADDR_LINE_3_TXT IS NOT NULL 
        OR DOMS.CITY_NM IS NOT NULL 
        OR DOMS.CTRY_SERV_CD IS NOT NULL 
        OR DOMS.PSTL_AREA_CD IS NOT NULL 
        OR DOMS.PSTL_AREA_CA_DLV_ROUTE_CD IS NOT NULL
) b
JOIN BNK22952_E225.FAM_INTERNET_TRAIN_2024_11_0825_03 a
    ON a.USAA_PARTY_PD_ID = b.PRTY_ID
GROUP BY a.USAA_PARTY_PD_ID, a.PARTITION_DT



SELECT 
    a.USAA_PARTY_PD_ID,
    a.PARTITION_DT,
    COUNT(DISTINCT lower(CUST_EMAIL_ADDR_TXT)) AS TOTAL_UNIQUE_EMAILS,
    DATEDIFF(
        'day',
        MAX(
            CASE 
                WHEN b.CNTC_PT_VER_GMT_TS <= a.PARTITION_DT THEN b.CNTC_PT_VER_GMT_TS 
