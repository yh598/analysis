# Function to generate SQL per partition date
def generate_partitioned_phone_feature_sql(base_table: str, phone_session_table: str, partition_date: str, n_days_list: list) -> str:
    date_obj = datetime.strptime(partition_date, '%Y-%m-%d')
    start_ts = (date_obj - timedelta(days=max(n_days_list))).strftime('%Y-%m-%d')
    end_ts = partition_date

