    final_sql = f"""
        SELECT
            a.USAA_PARTY_PD_ID,
            a.event_ts,
            COUNT(DISTINCT CASE 
                WHEN b.CNTC_PT_VER_GMT_TS < a.event_ts 
                THEN b.cleaned_phone_number 
            END) AS TOTAL_UNIQUE_PHONE,
            DATEDIFF(
                'day',
                MAX(CASE WHEN b.CNTC_PT_VER_GMT_TS < a.event_ts THEN b.CNTC_PT_VER_GMT_TS END),
                a.event_ts
            ) AS DAYS_SINCE_LAST_PHONE_CHANGE,
            {select_exprs}
        FROM {base_table} a
        LEFT JOIN phone_base b
          ON a.USAA_PARTY_PD_ID = b.USAA_PARTY_PD_ID
        GROUP BY a.USAA_PARTY_PD_ID, a.event_ts
    """

    result_df = session.sql(final_sql)
    result_df.create_or_replace_temp_view("phone")
    return result_df

